menu "Auto watering configuration"

config AUTO_WATERING_ENABLE_AUTOMATION
    bool "Enable automatic watering"
    default y

config AUTO_WATERING_ENABLE_ZIGBEE
    bool "Enable Zigbee resource publishing hooks"
    default n

config AUTO_WATERING_SAMPLE_PERIOD_MS
    int "Sensor sample period (ms)"
    range 1000 60000
    default 5000

config AUTO_WATERING_FILTER_ALPHA_PCT
    int "Filter alpha percent"
    range 1 100
    default 25

config AUTO_WATERING_DRY_THRESHOLD_PCT
    int "Dry threshold percent"
    range 0 100
    default 35

config AUTO_WATERING_WET_REFERENCE_RAW
    int "Wet calibration raw ADC reference"
    range 0 4095
    default 1200

config AUTO_WATERING_DRY_REFERENCE_RAW
    int "Dry calibration raw ADC reference"
    range 0 4095
    default 2800

config AUTO_WATERING_PUMP_GPIO
    int "Pump MOSFET GPIO"
    range 0 31
    default 10

config AUTO_WATERING_PUMP_MAX_RUNTIME_MS
    int "Pump max runtime (ms)"
    range 100 600000
    default 5000

config AUTO_WATERING_PUMP_LOCKOUT_MS
    int "Pump lockout after run (ms)"
    range 0 3600000
    default 60000

config AUTO_WATERING_AUTO_WATER_RUNTIME_MS
    int "Automatic watering runtime (ms)"
    range 100 600000
    default 3000

endmenu
